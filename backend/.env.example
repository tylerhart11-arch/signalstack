APP_NAME=SignalStack API
API_PREFIX=/api
FRONTEND_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql+psycopg://signalstack:signalstack@localhost:5432/signalstack
SIGNALSTACK_USE_DEMO_DATA=true
SIGNALSTACK_REFRESH_ON_STARTUP=true
SIGNALSTACK_BACKGROUND_REFRESH_ENABLED=true
SIGNALSTACK_REFRESH_INTERVAL_HOURS=1
SIGNALSTACK_EXCHANGE_CALENDAR=XNYS
SIGNALSTACK_MARKET_TIMEZONE=America/New_York
SIGNALSTACK_MARKET_OPEN_HOUR=9
SIGNALSTACK_MARKET_OPEN_MINUTE=30
SIGNALSTACK_MARKET_CLOSE_HOUR=16
SIGNALSTACK_MARKET_CLOSE_MINUTE=0
SIGNALSTACK_MARKET_LOOKBACK_DAYS=160
FRED_API_KEY=
